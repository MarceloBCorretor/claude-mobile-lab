# Chave da OpenRouter (https://openrouter.ai/keys). Necessaria para o chat funcionar.
OPENROUTER_API_KEY=

# Senha para entrar no chat E na area de administrador (/admin). Pode ser trocada
# depois pelo proprio painel admin (so muda a senha do admin; ao trocar, use a
# mesma para logar no chat).
ADMIN_PASSWORD=troque-esta-senha

# Segredo usado para assinar o cookie de sessao (chat + admin). Gere um valor aleatorio unico.
SESSION_SECRET=troque-este-segredo

# Porta usada quando rodando via "node server.js" (Hostinger/local). Ignorada na Vercel.
PORT=3000

# Opcional: string de conexao Postgres para guardar o historico de conversas no
# servidor (permite continuar a mesma conversa em outro aparelho). Sem isso, o
# historico e salvo em data/conversations.json - que funciona bem em hosts com
# disco persistente (Hostinger/local), mas NAO persiste na Vercel (filesystem
# efemero). Na Vercel, ative em Storage -> Create Database -> Postgres, que
# preenche esta variavel automaticamente.
POSTGRES_URL=
