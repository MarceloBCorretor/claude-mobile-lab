# Chave da OpenRouter (https://openrouter.ai/keys). Necessaria para o chat funcionar.
OPENROUTER_API_KEY=

# Senha inicial da area de administrador (/admin). Pode ser trocada depois pelo proprio painel.
ADMIN_PASSWORD=troque-esta-senha

# Segredo usado para assinar o cookie de sessao do admin. Gere um valor aleatorio unico.
SESSION_SECRET=troque-este-segredo

# Porta usada quando rodando via "node server.js" (Hostinger/local). Ignorada na Vercel.
PORT=3000
